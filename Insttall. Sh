#!/bin/bash
echo "🛡️ جاري تهيئة مِحْراب الراعي..."

# تثبيت المكتبات وتجاوز حماية النظام
pip install gspread google-auth requests --break-system-packages

# إنشاء المجلد إذا لم يكن موجوداً
mkdir -p ~/piety

# نقل السكربت للمكان الصحيح (إذا كان الطالب في مجلد التحميل)
cp piety_cli.py ~/piety/ 2>/dev/null

# إعطاء صلاحيات التنفيذ
chmod +x ~/piety/piety_cli.py

# إضافة الاختصار للنظام بشكل دائم
if ! grep -q "alias piety=" ~/.bashrc; then
    echo "alias piety='python3 ~/piety/piety_cli.py'" >> ~/.bashrc
fi

source ~/.bashrc
echo "🏛️ تم التثبيت بنجاح! اكتب الآن: piety"
